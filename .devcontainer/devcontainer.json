// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/javascript-node
{
	"name": "Zero Trust Assessment",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",

	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
		"ghcr.io/devcontainers/features/powershell:1": {}
	},

	// Ports:
	//   3000 — Docusaurus dev server (src/react)
	//   8080 — Assessment report HTTP server (auto-started after report generation)
	"forwardPorts": [3000, 8080],
	"portsAttributes": {
		"3000": { "label": "Docusaurus Site", "onAutoForward": "notify" },
		"8080": { "label": "Assessment Report", "onAutoForward": "openBrowser" }
	},

	// Install root + react site npm deps, create PS Scripts dir, install PS modules
	"postCreateCommand": "npm install && cd src/react && npm install && cd ../.. && sudo mkdir -p /opt/microsoft/powershell/7/Scripts && sudo chown node:node /opt/microsoft/powershell/7/Scripts && sudo chmod 755 /opt/microsoft/powershell/7/Scripts && pwsh -NoProfile -Command \"Install-Module -Name PSFramework, Pester, PSScriptAnalyzer -Force -Scope CurrentUser -AcceptLicense\"",

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.powershell",
				"docsmsft.docs-authoring-pack",
				"dbaeumer.vscode-eslint",
				"streetsidesoftware.code-spell-checker",
				"davidanson.vscode-markdownlint",
				"esbenp.prettier-vscode"
			],
			"settings": {
				"powershell.powerShellDefaultVersion": "PowerShell"
			}
		}
	}

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
