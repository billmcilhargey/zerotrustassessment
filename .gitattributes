# ─────────────────────────────────────────────────────────────────────────────
# Global text normalization — store LF in repo, convert on checkout as needed
# ─────────────────────────────────────────────────────────────────────────────
* text=auto

# ── Shell scripts — always LF (CRLF breaks on Linux/macOS) ───────────────────
*.sh text eol=lf

# ── Windows batch scripts — CRLF required (only applies if .bat files exist) ─
*.bat text eol=crlf

# ── PowerShell ───────────────────────────────────────────────────────────────
*.ps1   text
*.psm1  text
*.psd1  text
*.ps1xml text

# ── Web / config / data files ────────────────────────────────────────────────
*.json text
*.js   text
*.jsx  text
*.ts   text
*.tsx  text
*.css  text
*.md   text
*.yml  text
*.yaml text
*.csv  text
*.toml text
*.ini  text

# ── Programming languages ────────────────────────────────────────────────────
*.py   text
*.sql  text

# ── .NET project files (safe + recommended) ──────────────────────────────────
*.cs      text
*.csproj  text
*.sln     text

# ── Managed .NET bindings (tracked in src/powershell/lib/) ───────────────────
*.dll   binary
*.so    binary
*.dylib binary

# ── Images ───────────────────────────────────────────────────────────────────
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.svg  text

# ── Documents / Office ───────────────────────────────────────────────────────
*.xlsx binary
*.docx binary
*.pdf  binary

# ── Fonts ────────────────────────────────────────────────────────────────────
*.woff  binary
*.woff2 binary
*.eot   binary
*.ttf   binary
